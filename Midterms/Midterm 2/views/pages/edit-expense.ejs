<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("../partials/head", { title: "Edit Expense" }) %>
</head>
<body>
  <div class="layout">
    <%- include("../partials/sidebar", { active: "" }) %>

    <main class="main">
      <div class="main__header">
        <h1 class="page-title">Edit Expense</h1>
      </div>

      <section class="card card--modal">
        <h2 class="card__title">Edit "<%= expense.title %>"</h2>
        <p class="card__desc">Update the details below and save your changes.</p>
        <%- include("../partials/expense-form", {
          action: "/api/expenses/" + expense.id + "/update",
          submitLabel: "Save Changes",
          categories,
          expense,
          backHref: "/expenses/" + expense.id
        }) %>
      </section>
    </main>
  </div>
</body>
</html>
